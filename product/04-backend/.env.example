# AKS backend ortam değişkenleri — bu dosyayı .env olarak kopyalayıp doldurun.
# Hiçbiri zorunlu değil: boşsa demo yerel SQLite + bellek-içi cache ile çalışır.

# --- LLM (opsiyonel) ---
GEMINI_API_KEY=

# --- Supabase (Postgres) — boşsa yerel SQLite ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis — boşsa yerel bellek cache ---
REDIS_URL=

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-key-change-in-prod
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Veri / model yolu (opsiyonel override) ---
AKS_DATA_DIR=
AKS_MODEL=
